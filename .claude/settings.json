  {
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
      "allow": [
        "Bash(git status:*)",
        "Bash(git log:*)",
        "Bash(git diff:*)",
        "Bash(git show:*)",
        "Bash(git branch:*)",
        "Bash(git fetch:*)",
        "Bash(git pull:*)",
        "Bash(git add:*)",
        "Bash(git rm:*)",
        "Bash(git restore:*)"
      ]
    },
    "hooks": {
      "PreToolUse": [
        {
          "matcher": "Edit|Write|MultiEdit",
          "hooks": [
            {
              "type": "command",
              "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/guard-contract.sh",
              "timeout": 10,
              "statusMessage": "Checking framework contract..."
            }
          ]
        }
      ]
    }
  }
